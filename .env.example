# Copiar a /opt/nexus-brain/.env (o definir NEXUS_ROOT y ejecutar scripts/install.sh)
# Nunca commitear .env con valores reales.

# --- Dominios (TLS con Caddy; deben apuntar a esta VPS) ---
DOMAIN_CLAW=claw.tudominio.com
DOMAIN_SYNC=sync.tudominio.com

# --- OpenClaw / OpenWebUI en el HOST (ya instalado) ---
OPENCLAW_PORT=3000

# --- CouchDB (LiveSync) ---
COUCHDB_USER=admin
COUCHDB_PASSWORD=cambiar_por_password_larga_y_segura
COUCHDB_DATABASE=obsidian-livesync

# --- Ollama en Docker: modelos a descargar tras el arranque (separados por coma) ---
# VPS sin GPU: empezar con llama3.2:3b; opcional qwen2.5:7b-q4_K_M
OLLAMA_MODELS=llama3.2:3b

# --- RAG: watcher → Knowledge Base de OpenWebUI ---
OPENWEBUI_URL=http://127.0.0.1:3000
OPENWEBUI_API_KEY=
KNOWLEDGE_ID=

# --- Ruta del vault (Obsidian LiveSync + RAG) ---
VAULT_PATH=/opt/nexus-brain/vault
