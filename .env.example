# =============================================================================
# Nexus Brain — Variables de Entorno
# Copiar a .env (en la raíz del repo) y completar con valores reales.
# NUNCA commitear .env con valores reales.
#
# Inicio rápido:
#   cp .env.example .env && nano .env
#   sudo ./setup.sh
# =============================================================================

# --- Dominios (TLS con Caddy; deben apuntar a la IP de esta VPS) ---
DOMAIN_CLAW=claw.tudominio.com
DOMAIN_SYNC=sync.tudominio.com

# --- OpenClaw / OpenWebUI en el HOST (instalado por separado) ---
OPENCLAW_PORT=3000

# --- OpenClaw Admin (para configuración automática vía API) ---
# Se usa en configure-openclaw.sh para aplicar modelos y system prompt
OPENCLAW_ADMIN_EMAIL=admin@tudominio.com
OPENCLAW_ADMIN_PASSWORD=

# --- CouchDB (backend de Obsidian Self-hosted LiveSync) ---
COUCHDB_USER=admin
COUCHDB_PASSWORD=cambiar_por_password_larga_y_segura_min16chars
COUCHDB_DATABASE=obsidian-livesync

# --- Modelos Ollama ---
# PRIMARY_MODEL: modelo por defecto en OpenClaw (debe estar en OLLAMA_MODELS)
# OLLAMA_MODELS: lista CSV de modelos a descargar automáticamente al instalar
PRIMARY_MODEL=gemma4
OLLAMA_MODELS=gemma4

# URL base de Ollama (nativo en host o Docker)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Modelo Fallback: Gemini Flash via Google AI API (OpenAI-compatible) ---
# Obtenés tu API Key en: https://aistudio.google.com/apikey
# Se usa como provider secundario en OpenClaw cuando Ollama no está disponible
# o para tareas de enrutamiento de alta carga.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview

# --- RAG: watcher Markdown → Knowledge Base de OpenWebUI ---
OPENWEBUI_URL=http://127.0.0.1:3000
OPENWEBUI_API_KEY=
KNOWLEDGE_ID=

# --- Vault Obsidian ---
# VAULT_GIT_URL: repo Git a clonar/sincronizar (deja vacío si lo manejás manualmente)
VAULT_GIT_URL=https://github.com/Yigue/Obsdian-Vault.git
VAULT_GIT_BRANCH=main
# VAULT_PATH: dónde se monta el vault localmente
VAULT_PATH=/opt/nexus-brain/vault
